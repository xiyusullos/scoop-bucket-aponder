{
    "version": "5.17",
    "description": "An archiver which provides fast speed and convenient features",
    "homepage": "https://www.bandizip.com/",
    "license": {
        "identifier": "Freeware",
        "url": "https://en.bandisoft.com/bandizip/eula/"
    },
    "notes": [
        "Bandizip 5.17 is an older version. The latest version is available at https://www.bandizip.com/.",
        "",
        "To re-register context menu and file associations, run:",
        "reg import \"$dir\\install-context.reg\" && reg import \"$dir\\install-associations.reg\""
    ],
    "architecture": {
        "64bit": {
            "url": "https://media.githubusercontent.com/media/xiyusullos/scoop-bucket-bin/main/bandizip/bandizip@5.17.exe",
            "hash": "3185AFAD4B418E9F3BD8C76232407EA6B77DDC6659FEA746AB606F57F18C7BED",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\bandizip@5.17.exe\" \"$dir\" -Removal",
                "Remove-Item \"$dir\\Bandizip32.exe\", \"$dir\\RegDll32.exe\", \"$dir\\RegDll64.exe\" -Force -ErrorAction SilentlyContinue",
                "Remove-Item \"$dir\\`$PLUGINSDIR\" -Recurse -Force -ErrorAction SilentlyContinue",
                "if (!(Test-Path \"$persist_dir\\Bandizip.ini\")) { New-Item \"$dir\\Bandizip.ini\" -ItemType File | Out-Null }"
            ]
        }
    },
    "post_install": [
        "$dirpath = \"$dir\".Replace('\\', '\\\\')",
        "$exepath = \"$dir\\Bandizip64.exe\".Replace('\\', '\\\\')",
        "$dllpath = \"$dir\\bdzshl64.dll\".Replace('\\', '\\\\')",
        "'install-context','uninstall-context','install-associations','uninstall-associations' | ForEach-Object {",
        "  if (Test-Path \"$bucketsdir\\aponder\\scripts\\bandizip\\$_.reg\") {",
        "    $content = Get-Content \"$bucketsdir\\aponder\\scripts\\bandizip\\$_.reg\"",
        "    $content = $content.Replace('$bandizipdir', $dirpath)",
        "    $content = $content.Replace('$bandizipexe', $exepath)",
        "    $content = $content.Replace('$bandizipdll', $dllpath)",
        "    $content | Set-Content -Path \"$dir\\$_.reg\"",
        "  }",
        "}",
        "reg import \"$dir\\install-context.reg\"",
        "reg import \"$dir\\install-associations.reg\""
    ],
    "uninstaller": {
        "script": [
            "if (Test-Path \"$dir\\uninstall-context.reg\") { reg import \"$dir\\uninstall-context.reg\" }",
            "if (Test-Path \"$dir\\uninstall-associations.reg\") { reg import \"$dir\\uninstall-associations.reg\" }"
        ]
    },
    "bin": "Bandizip64.exe",
    "shortcuts": [
        [
            "Bandizip64.exe",
            "Bandizip"
        ]
    ],
    "persist": "Bandizip.ini"
}
